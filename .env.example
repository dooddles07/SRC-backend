# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# GHL Webhook URLs (copy from each workflow trigger)
GHL_WEBHOOK_BOOKING=https://services.leadconnectorhq.com/hooks/0h4aeb2m1HrDJ0coPb31/webhook-trigger/d6e07e32-86f0-45d1-b22c-011df9f86e4a
GHL_WEBHOOK_CANCELLATION=https://services.leadconnectorhq.com/hooks/0h4aeb2m1HrDJ0coPb31/webhook-trigger/e36ae7d2-d37a-47d1-8986-0a7385f3ce7c
GHL_WEBHOOK_GUEST_REGISTRATION=https://services.leadconnectorhq.com/hooks/0h4aeb2m1HrDJ0coPb31/webhook-trigger/591ae516-fdba-49af-ac1a-663b88b7dfe9
GHL_WEBHOOK_WALKIN=https://services.leadconnectorhq.com/hooks/0h4aeb2m1HrDJ0coPb31/webhook-trigger/4e78420a-6cb2-4cd1-a7d2-9e3399e09158
GHL_WEBHOOK_CHECKIN=https://services.leadconnectorhq.com/hooks/0h4aeb2m1HrDJ0coPb31/webhook-trigger/45eaf28e-188a-475e-a33d-f6a454dfe2c3

# GHL API (for check-in validation)
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_location_id_here
GHL_API_BASE_URL=https://services.leadconnectorhq.com

# CORS - your frontend domain
ALLOWED_ORIGIN=http://localhost:8080

# GHL Inbound Webhook Secret
# Set this to any random string, then add it as a header (x-ghl-secret) or
# query param (?secret=) on every GHL workflow that calls POST /api/webhooks/ghl
GHL_WEBHOOK_SECRET=change_this_to_a_random_secret
